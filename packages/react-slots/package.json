{
  "name": "@grlt-hub/react-slots",
  "version": "4.0.0-beta.1",
  "private": false,
  "description": "Declarative slot system for React. Build extensible, plugin-ready components with dynamic injection",
  "keywords": [
    "component-injection",
    "component-slots",
    "composable",
    "composition",
    "deferred-rendering",
    "dynamic-injection",
    "extensible-components",
    "grlt",
    "grlt-hub",
    "lazy-components",
    "lightweight",
    "modular-ui",
    "plugin-architecture",
    "react",
    "react-slots",
    "slot-pattern",
    "slots",
    "type-safe"
  ],
  "homepage": "https://github.com/grlt-hub/react-slots",
  "license": "MIT",
  "author": "Viktor Pasynok",
  "contributors": [
    {
      "name": "Viktor Pasynok",
      "url": "https://github.com/binjospookie"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grlt-hub/react-slots.git"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "vitest run --project unit",
    "lint": "knip && oxlint ./src"
  },
  "dependencies": {
    "use-sync-external-store": "^1.6.0"
  },
  "devDependencies": {
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/use-sync-external-store": "1.5.0",
    "happy-dom": "20.10.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "peerDependencies": {
    "react": ">=16.8.0 <20.0.0"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
