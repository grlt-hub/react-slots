---
// Custom site title: brand icon + two-tone "@grlt-hub/react-slots".
// Keeps Starlight's home link (siteTitleHref from the route data).
const { siteTitleHref } = Astro.locals.starlightRoute
---

<a href={siteTitleHref} class="site-title sl-flex" translate="no">
  <img src="/logo.png" alt="@grlt-hub/react-slots" width="128" height="128" />
  <span class="brand">
    <span class="brand-scope">@grlt-hub/</span><span class="brand-repo">react-slots</span>
  </span>
</a>

<style>
  .site-title {
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }

  .site-title img {
    height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
    width: auto;
    border-radius: 9px;
    object-fit: contain;
    flex: none;
  }

  .brand {
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .brand-scope {
    color: var(--sl-color-gray-3);
    font-weight: 400;
  }

  .brand-repo {
    color: var(--sl-color-white);
    font-weight: 400;
  }
</style>
